class Solution {
public:
    vector<int> leaders(vector<int>& nums) {
      vector<int>temp;
      int n = nums.size();
      int maxi = INT_MIN;

      for(int i = n-1; i>=0; i--){
        if(nums[i]>=maxi){
            temp.push_back(nums[i]);
            maxi = nums[i];
        }
      }

      reverse(temp.begin(),temp.end());

      return temp;
    }
};
