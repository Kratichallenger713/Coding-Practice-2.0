class Solution {
public:
    vector<int> twoSum(vector<int>& nums, int target) {
        unordered_map<int,int>found;

        for(int i=0; i<nums.size(); i++){
            int need = target-nums[i];
            if(found.find(need)!=found.end()){
                return {found[need],i};

            }
            found[nums[i]]=i;

        }
         return {};
    }
   
};
